{
  "name": "newtab",
  "version": "1.5.9",
  "description": "Custom new tab extension",
  "keywords": [
    "browser",
    "chrome",
    "extension",
    "newtab"
  ],
  "homepage": "https://github.com/xzy-nine/newtab",
  "bugs": {
    "url": "https://github.com/xzy-nine/newtab/issues"
  },
  "license": "MIT",
  "author": "xzy-nine",
  "repository": {
    "type": "git",
    "url": "https://github.com/xzy-nine/newtab.git"
  },
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox",
    "compile": "tsc --noEmit",
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "knip": "knip",
    "lint": "oxfmt --no-error-on-unmatched-pattern && oxlint --fix --no-error-on-unmatched-pattern",
    "postinstall": "wxt prepare",
    "preinstall": "npx only-allow bun",
    "prepare": "husky",
    "test:unit": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "zip": "wxt zip",
    "zip:edge": "wxt zip -b edge",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@reactuses/core": "^6.3.2",
    "@tailwindcss/vite": "^4.3.0",
    "acorn": "^8.17.0",
    "boolbase": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern --write",
      "oxlint --fix --no-error-on-unmatched-pattern"
    ],
    "*.json": "oxfmt --no-error-on-unmatched-pattern --write"
  },
  "packageManager": "bun@1.3.14"
}
